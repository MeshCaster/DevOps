# Local development only. On a real server, deploy with generated secrets via
# tools/infra/deploy-common-infra.sh — which sets these in the environment and
# leaves NO .env file on the host.
#
#   cp .env.example .env   # then docker compose up -d

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# RabbitMQ
RABBITMQ_DEFAULT_USER=rabbit
RABBITMQ_DEFAULT_PASS=change-me

# Redis
REDIS_PASSWORD=change-me
